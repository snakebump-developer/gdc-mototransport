# =================================================================
# ESEMPIO DI CONFIGURAZIONE — copia questo file in .env e compila
# tutti i valori prima di avviare l'applicazione.
# ⚠️  NON committare mai il file .env, solo questo .env.example
# =================================================================

# Ambiente (development | production)
APP_ENV=development
APP_DEBUG=true

# Applicazione
APP_NAME=Nome Azienda Cliente
APP_URL=https://dominio-cliente.it

# Database MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nome_database
DB_USER=utente_db
DB_PASSWORD=password_db

# Admin di default — usato da src/setup.php al primo avvio
ADMIN_USERNAME=admin_username
ADMIN_PASSWORD=Admin@Password1!
ADMIN_EMAIL=admin@dominio-cliente.it

# Sicurezza — password modalità manutenzione
MAINTENANCE_PASSWORD=Password@Manutenzione1!

# Dati aziendali (footer, WhatsApp, link "Chiama Ora")
COMPANY_NAME=Nome Azienda
COMPANY_ADDRESS=Via Roma 1, 00100 Roma (RM)
COMPANY_PHONE=+39 000 000 0000
COMPANY_PHONE_TEL=+390000000000
COMPANY_EMAIL=info@dominio-cliente.it
COMPANY_WHATSAPP=39000000000

# Stripe → https://dashboard.stripe.com/apikeys
# Test:       sk_test_... / pk_test_...
# Produzione: sk_live_... / pk_live_...
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PayPal → https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Google Maps → https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Utenti di test (solo sviluppo — non usare in produzione)
TEST_USER_USERNAME=user_test
TEST_USER_PASSWORD=Test@Password1
TEST_USER_EMAIL=user@test.it
TEST_PRO_USERNAME=pro_test
TEST_PRO_PASSWORD=Pro@Password1
TEST_PRO_EMAIL=pro@test.it
