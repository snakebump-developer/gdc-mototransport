# =================================================================
# ESEMPIO DI CONFIGURAZIONE — copia questo file in .env e compila
# tutti i valori prima di avviare l'applicazione.
# ⚠️  NON committare mai il file .env, solo questo .env.example
# =================================================================

# Ambiente (development | production)
APP_ENV=development
APP_DEBUG=true

# Applicazione
APP_NAME=Nome Azienda Cliente
APP_URL=https://dominio-cliente.it

# Database MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nome_database
DB_USER=utente_db
DB_PASSWORD=password_db

# Admin di default — usato da src/setup.php al primo avvio
ADMIN_USERNAME=admin_username
ADMIN_PASSWORD=Admin@Password1!
ADMIN_EMAIL=admin@dominio-cliente.it

# Sicurezza — password modalità manutenzione
MAINTENANCE_PASSWORD=Password@Manutenzione1!

# Dati aziendali (footer, WhatsApp, link "Chiama Ora")
COMPANY_NAME=Nome Azienda
COMPANY_ADDRESS=Via Roma 1, 00100 Roma (RM)
COMPANY_PHONE=+39 000 000 0000
COMPANY_PHONE_TEL=+390000000000
COMPANY_EMAIL=info@dominio-cliente.it
COMPANY_WHATSAPP=39000000000

# Stripe → https://dashboard.stripe.com/apikeys
# Test:       sk_test_... / pk_test_...
# Produzione: sk_live_... / pk_live_...
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PayPal → https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Google Maps → https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =================================================================
# LETTERA DI VETTURA / DOCUMENTO DI TRASPORTO
# Dati fissi del vettore, conducente e assicurazione
# (D.Lgs. 286/2005 — Art. 1678 e ss. Codice Civile)
# =================================================================

# Dati Vettore (azienda di trasporto)
VETTORE_RAGIONE_SOCIALE=GDC MotoTransport S.r.l.
VETTORE_PIVA=IT12345678901
VETTORE_INDIRIZZO=Via del Trasporto 1
VETTORE_CAP=20100
VETTORE_CITTA=Milano
VETTORE_PROVINCIA=MI
VETTORE_TELEFONO=+39 02 1234 5678
VETTORE_EMAIL=info@gdcmototransport.it
# Numero iscrizione Albo Nazionale degli Autotrasportatori (REN)
VETTORE_REN=REN-123456-IT

# Dati Conducente (fisso — aggiornare in produzione)
CONDUCENTE_NOME=Mario
CONDUCENTE_COGNOME=Rossi
CONDUCENTE_PATENTE=IT-A1B2C3D4E5
CONDUCENTE_PATENTE_CAT=CE
CONDUCENTE_TELEFONO=+39 333 000 1111

# Dati Mezzo di Trasporto
MEZZO_TIPO=Furgone chiuso
MEZZO_TARGA=AB123CD
MEZZO_MARCA=Mercedes-Benz
MEZZO_MODELLO=Sprinter 316 CDI
MEZZO_RIMORCHIO_TARGA=

# Assicurazione RC Merci
ASSICURAZIONE_COMPAGNIA=Sara Assicurazioni S.p.A.
ASSICURAZIONE_POLIZZA=RC-MERCI-00123456
ASSICURAZIONE_SCADENZA=31/12/2026
ASSICURAZIONE_MASSIMALE=€ 1.000.000,00

# =================================================================
# Utenti di test (solo sviluppo — non usare in produzione)
TEST_USER_USERNAME=user_test
TEST_USER_PASSWORD=Test@Password1
TEST_USER_EMAIL=user@test.it
TEST_PRO_USERNAME=pro_test
TEST_PRO_PASSWORD=Pro@Password1
TEST_PRO_EMAIL=pro@test.it
